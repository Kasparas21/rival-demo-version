# Required for live ad scrapes (never expose client-side)
APIFY_TOKEN=

# Optional actor overrides
# APIFY_SNAPCHAT_ADS_ACTOR=zadexinho/snapchat-ads-scraper

# Supabase (see src/lib/supabase/env.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Public app origin used for SEO and payment redirects.
NEXT_PUBLIC_APP_URL=https://spy-rival.com

# Polar billing (server-only except the public app URL above).
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=a105e33c-ab82-4649-8740-c7a799f654bc
POLAR_SERVER=production

# Resend (magic link emails — avoids Supabase’s built-in email rate limits).
# 1) Copy your Resend API key into this app’s env (Vercel / .env.local). Supabase Dashboard “secrets”
#    named `resend` are for Edge Functions only; mirror the same value here as RESEND_API_KEY or `resend`.
# 2) Optional: RESEND_FROM_EMAIL="Spy Rival <hello@spy-rival.com>" (default is onboarding@resend.dev for testing).
# If RESEND_API_KEY is unset, the login page falls back to Supabase Auth email (OTP).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Spy Rival <hello@spy-rival.com>"

#
# Google sign-in: enable the Google provider in Supabase Dashboard (Authentication → Providers → Google).
# In the same project, add these to Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   <your-production-origin>/auth/callback
# Site URL should match the app origin you use (e.g. http://localhost:3000 for local dev).

# Firecrawl discover API
FIRECRAWL_API_KEY=

# Google ad details in UI (optional)
# NEXT_PUBLIC_GOOGLE_AD_DETAILS=false

# Dev-only: instant email sign-in via admin API (never enable in production).
# Real auth is the default (magic link + Google). Set to "true" only for local convenience.
# NEXT_PUBLIC_DEV_INSTANT_EMAIL_LOGIN=true
